<?xml version="1.0" encoding="UTF-8" ?>
<!--
  OmniBlue Fast DDS profile (PC side)
  - Pins discovery to the Omniblue Wi-Fi interface (192.168.0.100)
    plus loopback (127.0.0.1) so PC-internal nodes can find each other.
  - SHM transport added for fast intra-host pub/sub.
  - Disables multicast in favor of explicit unicast peers (fleet-ready).
  - Peers list includes future omniblue2 (.13) and omniblue3 (.14).
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>udp_omniblue</transport_id>
            <type>UDPv4</type>
            <interfaceWhiteList>
                <address>192.168.0.101</address>
                <address>127.0.0.1</address>
            </interfaceWhiteList>
        </transport_descriptor>
        <transport_descriptor>
            <transport_id>shm_omniblue</transport_id>
            <type>SHM</type>
        </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="omniblue_participant" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>shm_omniblue</transport_id>
                <transport_id>udp_omniblue</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
            <builtin>
                <initialPeersList>
                    <locator>
                        <udpv4>
                            <address>192.168.0.12</address>
                        </udpv4>
                    </locator>
                    <locator>
                        <udpv4>
                            <address>192.168.0.13</address>
                        </udpv4>
                    </locator>
                    <locator>
                        <udpv4>
                            <address>192.168.0.14</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
                <avoid_builtin_multicast>false</avoid_builtin_multicast>
            </builtin>
        </rtps>
    </participant>
</profiles>
