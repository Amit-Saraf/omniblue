        </script>
      </material>
    </visual>
  </link>
  <pose>13.5 33.5 0.005 0 0 0</pose>  <!-- 中心点在(13.5,33.5,0.005) -->
</model>

<!-- 路径段 5: 从 (13.5,37) 到 (-10,37) - 水平段 -->
<model name="red_path_segment_5">
  <static>true</static>
  <link name="link">
    <collision name="collision">
      <geometry>
        <box>
          <size>23.5 0.1 0.01</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <box>
          <size>23.5 0.1 0.01</size>
