  </link>
  <pose>7.25 30 0.005 0 0 0</pose>  <!-- 中心点在(7.25,30,0.005) -->
</model>

<!-- 路径段 4: 从 (13.5,30) 到 (13.5,37) - 垂直段 -->
<model name="red_path_segment_4">
  <static>true</static>
  <link name="link">
    <collision name="collision">
      <geometry>
        <box>
          <size>0.1 7 0.01</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
